# Bear Castle AI gateway configuration example.
# Copy to .env and edit for your host, database, and local AI service URLs.

NODE_ENV=development
HOST=127.0.0.1
PORT=3000
APP_NAME=Bear Castle AI
APP_DEFAULT_USER_NAME=Eric

# HTTPS / reverse-proxy behavior
HTTPS_REDIRECT_ENABLED=false
HTTPS_REDIRECT_ALLOWED_HOSTS=
HTTPS_REDIRECT_STATUS_CODE=308

# Database
DATABASE_URL=postgresql://local_ai_gateway:change_me@localhost:5432/local_ai_gateway

# Authentication and sessions
# Replace these before using NODE_ENV=production.
AUTH_ENABLED=true
INITIAL_ADMIN_PASSWORD=change_this_admin_password
NEW_USER_DEFAULT_PASSWORD=change_this_default_user_password
AUTH_MIN_PASSWORD_LENGTH=8
SESSION_SECRET=change_this_to_a_long_random_secret
SESSION_COOKIE_NAME=bear_castle_ai_session
SESSION_TTL_HOURS=12
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAME_SITE=lax
AUTH_TRUST_PROXY=true

AUTH_MAX_FAILED_LOGIN_ATTEMPTS=3
AUTH_LOCKOUT_WINDOW_MINUTES=5
AUTH_LOCKOUT_DURATION_MINUTES=5
AUTH_LOGIN_RATE_LIMIT_WINDOW_MS=900000
AUTH_LOGIN_RATE_LIMIT_MAX=20

# Security
CSRF_ENABLED=true
CSRF_HEADER_NAME=X-CSRF-Token
SECURITY_HEADERS_ENABLED=true
CORS_ALLOWED_ORIGINS=

# Rate limits
CHAT_RATE_LIMIT_WINDOW_MS=60000
CHAT_RATE_LIMIT_MAX=20
TRANSCRIBE_RATE_LIMIT_WINDOW_MS=60000
TRANSCRIBE_RATE_LIMIT_MAX=10
TTS_RATE_LIMIT_WINDOW_MS=60000
TTS_RATE_LIMIT_MAX=20
ADMIN_RATE_LIMIT_WINDOW_MS=60000
ADMIN_RATE_LIMIT_MAX=30

# Local LLM service
LLM_BASE_URL=http://192.168.1.5:11434
LLM_MONITOR_BASE_URL=http://192.168.1.5:8000
LLM_MODEL=qwen3:30b
LLM_TIMEOUT_MS=600000

# Local LLM model-management settings
MODEL_DISCOVERY_TIMEOUT_MS=30000
MODEL_DETAILS_TIMEOUT_MS=30000
MODEL_PULL_TIMEOUT_MS=3600000
MODEL_DELETE_TIMEOUT_MS=120000
MODEL_MAX_CONCURRENT_PULLS=1

# Local LLM storage telemetry
LLM_STORAGE_ENDPOINT=/storage
STORAGE_LOW_DISK_WARNING_PERCENT=85
STORAGE_LOW_DISK_WARNING_BYTES=53687091200

# Server-side image generation through local-ai-llm
IMAGE_GENERATION_ENABLED=false
IMAGE_GENERATION_TIMEOUT_MS=600000
IMAGE_GENERATION_MAX_PROMPT_CHARS=4000
IMAGE_GENERATION_STORAGE_DIR=./storage/generated-images

# Local voice service
VOICE_BASE_URL=http://192.168.1.8:8000
VOICE_TIMEOUT_MS=300000

# Text-to-speech uses local-ai-voice POST /api/tts/speak through the gateway.
TTS_ENABLED=true
TTS_DEFAULT_PROVIDER=chatterbox
TTS_EXPLICIT_PROVIDER=true
TTS_FALLBACK_POLICY=fail
TTS_DEFAULT_VOICE=af_heart
TTS_DEFAULT_SPEED=1.0
TTS_TIMEOUT_MS=120000
TTS_MAX_TEXT_CHARS=12000

# Chatterbox TTS provider defaults.
TTS_CHATTERBOX_ENABLED=true
TTS_CHATTERBOX_DEFAULT_MODEL=chatterbox-turbo
TTS_CHATTERBOX_DEFAULT_VOICE=reference-upload

# Kokoro TTS provider defaults.
# Must match a model accepted by the local-ai-voice Kokoro worker.
TTS_KOKORO_ENABLED=true
TTS_KOKORO_DEFAULT_MODEL=kokoro-82m
TTS_KOKORO_DEFAULT_VOICE=af_heart

# Optional transcript formatting through the local LLM.
# Leave TRANSCRIPT_FORMATTING_MODEL blank to use the current default LLM model at request time.
TRANSCRIPT_FORMATTING_ENABLED=false
TRANSCRIPT_FORMATTING_TIMEOUT_MS=120000
TRANSCRIPT_FORMATTING_MODEL=
TRANSCRIPT_FORMATTING_MAX_CHARS=12000

# Conversation title generation.
# Leave CONVERSATION_TITLE_MODEL blank to use the current default LLM model at request time.
CONVERSATION_TITLE_GENERATION_ENABLED=true
CONVERSATION_TITLE_MODEL=
CONVERSATION_TITLE_TIMEOUT_MS=120000
CONVERSATION_TITLE_MAX_CHARS=4000
CONVERSATION_TITLE_MAX_LENGTH=80

# Health/GPU telemetry
HEALTH_POLL_INTERVAL_MS=5000
GPU_POLL_INTERVAL_MS=2000
TELEMETRY_STALE_AFTER_MS=15000

# Conversation prompt context limits
CONVERSATION_CONTEXT_MAX_MESSAGES=20
CONVERSATION_CONTEXT_MAX_CHARS=24000

# Browser recording uploads
UPLOAD_DIR=./storage/uploads
STORE_AUDIO_UPLOADS=false
MAX_AUDIO_UPLOAD_MB=50

# Logging
LOG_LEVEL=info
