# Bear Castle AI production example for Ubuntu Server behind a TLS reverse proxy.
# Copy this file to .env, replace every change_this... value, and keep .env out of git.

NODE_ENV=production
APP_NAME=Bear Castle AI

# Recommended for HTTPS hosting behind Caddy or Nginx: keep Node private on localhost.
# The reverse proxy listens publicly on 80/443 and forwards to http://127.0.0.1:3000.
HOST=127.0.0.1
PORT=3000

DATABASE_URL=postgresql://local_ai_gateway:change_me@localhost:5432/local_ai_gateway

AUTH_ENABLED=true
INITIAL_ADMIN_PASSWORD=change_this_admin_password
NEW_USER_DEFAULT_PASSWORD=change_this_default_user_password
AUTH_MIN_PASSWORD_LENGTH=8
SESSION_SECRET=change_this_to_a_long_random_secret
SESSION_COOKIE_NAME=bear_castle_ai_session
SESSION_TTL_HOURS=12
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAME_SITE=lax
AUTH_TRUST_PROXY=true
AUTH_MAX_FAILED_LOGIN_ATTEMPTS=3
AUTH_LOCKOUT_WINDOW_MINUTES=5
AUTH_LOCKOUT_DURATION_MINUTES=5
AUTH_LOGIN_RATE_LIMIT_WINDOW_MS=900000
AUTH_LOGIN_RATE_LIMIT_MAX=20
CSRF_ENABLED=true
CSRF_HEADER_NAME=X-CSRF-Token

# Same-origin HTTPS deployments can leave this blank.
# If you intentionally serve the frontend and API from different origins, set the exact HTTPS origin,
# for example: CORS_ALLOWED_ORIGINS=https://gateway.msdos.games
CORS_ALLOWED_ORIGINS=
SECURITY_HEADERS_ENABLED=true

CHAT_RATE_LIMIT_WINDOW_MS=60000
CHAT_RATE_LIMIT_MAX=20
TRANSCRIBE_RATE_LIMIT_WINDOW_MS=60000
TRANSCRIBE_RATE_LIMIT_MAX=10
ADMIN_RATE_LIMIT_WINDOW_MS=60000
ADMIN_RATE_LIMIT_MAX=30

LLM_BASE_URL=http://192.168.1.5:11434
LLM_MONITOR_BASE_URL=http://192.168.1.5:8000
LLM_MODEL=qwen3:30b
LLM_TIMEOUT_MS=600000

VOICE_BASE_URL=http://192.168.1.8:8000
VOICE_TIMEOUT_MS=300000

TRANSCRIPT_FORMATTING_ENABLED=false
TRANSCRIPT_FORMATTING_TIMEOUT_MS=120000
TRANSCRIPT_FORMATTING_MODEL=qwen3:30b
TRANSCRIPT_FORMATTING_MAX_CHARS=12000

CONVERSATION_TITLE_GENERATION_ENABLED=true
CONVERSATION_TITLE_MODEL=qwen3:30b
CONVERSATION_TITLE_TIMEOUT_MS=120000
CONVERSATION_TITLE_MAX_CHARS=4000
CONVERSATION_TITLE_MAX_LENGTH=80

HEALTH_POLL_INTERVAL_MS=5000
GPU_POLL_INTERVAL_MS=2000
TELEMETRY_STALE_AFTER_MS=15000

CONVERSATION_CONTEXT_MAX_MESSAGES=20
CONVERSATION_CONTEXT_MAX_CHARS=24000

# Browser recordings are uploaded through the gateway before being forwarded to local-ai-voice.
# Keep the reverse proxy upload limit at or above this value.
MAX_AUDIO_UPLOAD_MB=50
STORE_AUDIO_UPLOADS=false
UPLOAD_DIR=./storage/uploads

LOG_LEVEL=info
