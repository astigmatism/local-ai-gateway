# ============================================================
# Bear Castle AI gateway configuration
# ============================================================

NODE_ENV=development
HOST=0.0.0.0
PORT=3000
APP_NAME=Bear Castle AI

# ============================================================
# Database
# ============================================================
# For local development, replace change_me with your local database password.
# Production deployments should use their real production DATABASE_URL.
DATABASE_URL=postgresql://local_ai_gateway:change_me@localhost:5432/local_ai_gateway?schema=public

# ============================================================
# HTTPS / reverse-proxy behavior
# ============================================================
# In development, HTTPS redirect is usually disabled.
# In production behind Nginx/Caddy/another reverse proxy, enable this if the app should redirect HTTP to HTTPS.
HTTPS_REDIRECT_ENABLED=false
HTTPS_REDIRECT_ALLOWED_HOSTS=
HTTPS_REDIRECT_STATUS_CODE=308

# ============================================================
# Authentication and sessions
# ============================================================

AUTH_ENABLED=true
INITIAL_ADMIN_PASSWORD=change_this_initial_password
NEW_USER_DEFAULT_PASSWORD=change_this_new_user_password
AUTH_MIN_PASSWORD_LENGTH=8

# Use a long random value. At least 32 characters is recommended.
SESSION_SECRET=replace_with_a_long_random_secret_at_least_32_chars
SESSION_COOKIE_NAME=bear_castle_ai_session
SESSION_TTL_HOURS=12

# Use false for local HTTP development.
# Use true for HTTPS production deployments.
SESSION_COOKIE_SECURE=false

SESSION_COOKIE_SAME_SITE=lax

# Use false for direct local development.
# Use true when running behind a trusted reverse proxy.
AUTH_TRUST_PROXY=false

AUTH_MAX_FAILED_LOGIN_ATTEMPTS=3
AUTH_LOCKOUT_WINDOW_MINUTES=5
AUTH_LOCKOUT_DURATION_MINUTES=5
AUTH_LOGIN_RATE_LIMIT_WINDOW_MS=900000
AUTH_LOGIN_RATE_LIMIT_MAX=20

# ============================================================
# Security
# ============================================================

CSRF_ENABLED=true
CSRF_HEADER_NAME=X-CSRF-Token
SECURITY_HEADERS_ENABLED=true

# Comma-separated list of allowed browser origins.
# Leave blank when same-origin only.
CORS_ALLOWED_ORIGINS=

# ============================================================
# Rate limits
# ============================================================

CHAT_RATE_LIMIT_WINDOW_MS=60000
CHAT_RATE_LIMIT_MAX=20

TRANSCRIBE_RATE_LIMIT_WINDOW_MS=60000
TRANSCRIBE_RATE_LIMIT_MAX=10

TTS_RATE_LIMIT_WINDOW_MS=60000
TTS_RATE_LIMIT_MAX=20

ADMIN_RATE_LIMIT_WINDOW_MS=60000
ADMIN_RATE_LIMIT_MAX=30

# ============================================================
# Local LLM service
# ============================================================

LLM_BASE_URL=http://192.168.1.5:11434
LLM_MONITOR_BASE_URL=http://192.168.1.5:8000
LLM_MODEL=qwen3:30b
LLM_TIMEOUT_MS=600000

# ============================================================
# Local LLM model-management settings
# ============================================================
# These support model discovery, detail lookup, pulling, deleting, and concurrency limits.

MODEL_DISCOVERY_TIMEOUT_MS=30000
MODEL_DETAILS_TIMEOUT_MS=30000
MODEL_PULL_TIMEOUT_MS=3600000
MODEL_DELETE_TIMEOUT_MS=120000
MODEL_MAX_CONCURRENT_PULLS=1

# ============================================================
# Local LLM storage telemetry
# ============================================================
# LLM_STORAGE_ENDPOINT is relative to LLM_MONITOR_BASE_URL unless the app expects otherwise.
# STORAGE_LOW_DISK_WARNING_BYTES defaults here to 50 GiB.

LLM_STORAGE_ENDPOINT=/storage
STORAGE_LOW_DISK_WARNING_PERCENT=85
STORAGE_LOW_DISK_WARNING_BYTES=53687091200

# ============================================================
# Local voice service
# ============================================================

VOICE_BASE_URL=http://192.168.1.8:8000
VOICE_TIMEOUT_MS=300000

# ============================================================
# Text-to-speech
# ============================================================
# Text-to-speech uses local-ai-voice POST /speak through the gateway.
# Playback should only happen when the user manually clicks a speak action.

TTS_ENABLED=true
TTS_DEFAULT_VOICE=af_heart
TTS_DEFAULT_SPEED=1.0
TTS_TIMEOUT_MS=120000
TTS_MAX_TEXT_CHARS=12000

# ============================================================
# Optional transcript formatting through the local LLM
# ============================================================
# Leave TRANSCRIPT_FORMATTING_MODEL blank to use the default LLM_MODEL if fallback is supported.

TRANSCRIPT_FORMATTING_ENABLED=false
TRANSCRIPT_FORMATTING_TIMEOUT_MS=120000
TRANSCRIPT_FORMATTING_MODEL=
TRANSCRIPT_FORMATTING_MAX_CHARS=12000

# ============================================================
# Conversation title generation
# ============================================================
# Leave CONVERSATION_TITLE_MODEL blank to use the default LLM_MODEL if fallback is supported.

CONVERSATION_TITLE_GENERATION_ENABLED=true
CONVERSATION_TITLE_MODEL=
CONVERSATION_TITLE_TIMEOUT_MS=120000
CONVERSATION_TITLE_MAX_CHARS=4000
CONVERSATION_TITLE_MAX_LENGTH=80

# ============================================================
# Health/GPU telemetry
# ============================================================

HEALTH_POLL_INTERVAL_MS=5000
GPU_POLL_INTERVAL_MS=2000
TELEMETRY_STALE_AFTER_MS=15000

# ============================================================
# Conversation prompt context limits
# ============================================================

CONVERSATION_CONTEXT_MAX_MESSAGES=20
CONVERSATION_CONTEXT_MAX_CHARS=24000

# ============================================================
# Browser recording uploads
# ============================================================

MAX_AUDIO_UPLOAD_MB=50
STORE_AUDIO_UPLOADS=false
UPLOAD_DIR=./storage/uploads

# ============================================================
# Logging
# ============================================================

LOG_LEVEL=info
